# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather. For local dev use ngrok to expose localhost.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Random string you invent — must match what you set when registering the webhook
TELEGRAM_WEBHOOK_SECRET=some-random-secret-string

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key (not anon)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Lemon Squeezy ────────────────────────────────────────────────────────────
# Found in: lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=eyJ...
LEMONSQUEEZY_STORE_ID=12345
LEMONSQUEEZY_PRODUCT_ID=67890
# Signing secret for webhook verification — set in LS Dashboard → Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=some-lemon-secret
# Full checkout URL for the subscription product (from LS Dashboard → Products → Share)
LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/YOUR-VARIANT-ID

# ─── Public site URL (used for OG tags and canonical links) ───────────────────
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app
# Full Telegram bot URL (shown on landing page)
NEXT_PUBLIC_BOT_URL=https://t.me/YOUR_BOT_USERNAME

# ─── Railway Scraping Worker ──────────────────────────────────────────────────
# URL of the Railway service after deploy (e.g. https://food-agent-worker.up.railway.app)
SCRAPER_WORKER_URL=http://localhost:3001
# Shared secret between Next.js and the worker — you invent this string
SCRAPER_WORKER_SECRET=some-worker-secret

# ─── Owner notifications ───────────────────────────────────────────────────────
# Your personal Telegram user ID (get it from @userinfobot)
OWNER_TELEGRAM_ID=123456789

# ─── Vercel Cron auth ─────────────────────────────────────────────────────────
# Random string — set as CRON_SECRET in Vercel env vars, Vercel sends it as Bearer token
CRON_SECRET=some-cron-secret

# ─── Public app URL (used in weekly report dashboard link) ────────────────────
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
