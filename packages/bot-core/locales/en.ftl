# Base strings — override in project locales/en.ftl

unknown-command = Enter a command or use the menu.

error-generic = Something went wrong. Please try again.

trial-expired =
    ⏰ Your free trial has ended.

    Subscribe to keep going:

subscribe-btn = 💳 Subscribe

rate-limit = Please wait a moment before your next request.

# Refund — see DECISIONS.md 2026-05-15
refund-approved = We detected a technical issue with your purchase and refunded it in full. The amount returns to your payment method within { $days } business days. Sorry for the trouble — you're welcome to try again anytime.

refund-declined = We've reviewed your refund request. It falls outside our refund policy ({ $policyUrl }), so we're unable to refund in this case. If you think this is a mistake, just reply to this message.

# Voice transcription fallback — see DECISIONS.md 2026-05-14
voice-error-api-error = Couldn't transcribe right now — please try again or send text.

voice-error-too-large = Voice message too long — please send shorter audio or text.

voice-error-empty-result = Couldn't make out what you said — please try again or send text.
